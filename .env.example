# BookFlow local-development configuration.
# Copy to .env and replace every CHANGE_ME value before exposing any port.

# Application
APP_ENV=development
APP_NAME=bookflow
LOG_LEVEL=info
LOG_FORMAT=json
TZ=UTC

# HTTP server
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s
HTTP_TRUSTED_PROXIES=
PUBLIC_API_URL=http://localhost:8080
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=BookFlow

# PostgreSQL (development-only values; use a secret manager in production)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bookflow
POSTGRES_USER=bookflow
POSTGRES_PASSWORD=bookflow_dev_only
POSTGRES_SSLMODE=disable
DATABASE_URL=postgres://bookflow:bookflow_dev_only@postgres:5432/bookflow?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m
DB_PING_TIMEOUT=5s

# RustFS / S3. The keys below are development-only and intentionally obvious.
RUSTFS_IMAGE=rustfs/rustfs:1.0.0-beta.4
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_PUBLIC_ENDPOINT=http://localhost:9000
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY=bookflow_dev
RUSTFS_SECRET_KEY=bookflow_dev_only_change_me
RUSTFS_USE_PATH_STYLE=true
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_PRESIGN_TTL=5m
RUSTFS_OPERATION_TIMEOUT=30s
RUSTFS_MAX_RETRIES=3
RUSTFS_BUCKET_BOOKS_ORIGINAL=books-original
RUSTFS_BUCKET_BOOKS_CONTENT=books-content
RUSTFS_BUCKET_BOOKS_ASSETS=books-assets
RUSTFS_BUCKET_BOOKS_COVERS=books-covers
RUSTFS_BUCKET_USER_EXPORTS=user-exports

# Authentication and browser security. Generate with: openssl rand -base64 48
JWT_ISSUER=bookflow
JWT_AUDIENCE=bookflow-web
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_SIGNING_KEY=CHANGE_ME_generate_at_least_32_random_bytes
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2
COOKIE_NAME=bookflow_session
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
CSRF_SECRET=CHANGE_ME_generate_a_separate_random_secret
CSRF_COOKIE_NAME=bookflow_csrf

# Translation. `mock` requires no external network or API key.
TRANSLATION_PROVIDER=mock
TRANSLATION_API_KEY=
TRANSLATION_ENDPOINT=https://api.openai.com/v1/responses
TRANSLATION_MODEL=gpt-4.1-mini
TRANSLATION_PROMPT_VERSION=v1
TRANSLATION_TIMEOUT=10s
TRANSLATION_MAX_WORD_RUNES=128
TRANSLATION_MAX_TEXT_RUNES=2000
TRANSLATION_CACHE_TTL=720h
TRANSLATION_MAX_RETRIES=2

# Worker and PostgreSQL-backed job queue
WORKER_ID=bookflow-worker-local
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=1s
WORKER_JOB_TIMEOUT=5m
WORKER_HEARTBEAT_INTERVAL=15s
WORKER_MAX_ATTEMPTS=5
WORKER_STALE_LOCK_AFTER=10m
WORKER_STALE_SESSION_INTERVAL=1m
WORKER_STATS_INTERVAL=5m
WORKER_CACHE_CLEANUP_INTERVAL=1h

# Reader activity accounting
READING_HEARTBEAT_INTERVAL=15s
READING_HEARTBEAT_GRACE=10s
READING_IDLE_THRESHOLD=60s
READING_MAX_CREDIT_INTERVAL=30s
READING_STALE_AFTER=2m

# Request and upload limits
MAX_REQUEST_BODY_BYTES=1048576
UPLOAD_MAX_BYTES=104857600
EPUB_MAX_FILES=10000
EPUB_MAX_UNCOMPRESSED_BYTES=524288000
EPUB_MAX_COMPRESSION_RATIO=100

# Rate limits (requests/window)
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_TRANSLATION=60
RATE_LIMIT_WINDOW=1m

# CORS. Comma-separated exact origins; never use `*` with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Idempotency-Key,If-Match,X-CSRF-Token,X-Request-ID
CORS_ALLOW_CREDENTIALS=true

# OpenTelemetry. Enable when using the Compose `observability` profile.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bookflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_TRACE_RATIO=1.0
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development,service.namespace=bookflow

# Uptrace local profile. Development-only bootstrap credentials and tokens.
UPTRACE_IMAGE=uptrace/uptrace:2.1.0-beta.7
UPTRACE_SECRET=CHANGE_ME_uptrace_service_secret
UPTRACE_ADMIN_EMAIL=admin@uptrace.local
UPTRACE_ADMIN_PASSWORD=CHANGE_ME_uptrace_admin_password
UPTRACE_USER_TOKEN=CHANGE_ME_uptrace_user_token
UPTRACE_PROJECT_TOKEN=CHANGE_ME_bookflow_project_token
UPTRACE_POSTGRES_PASSWORD=CHANGE_ME_uptrace_postgres_password
UPTRACE_CLICKHOUSE_PASSWORD=CHANGE_ME_uptrace_clickhouse_password
UPTRACE_REDIS_PASSWORD=CHANGE_ME_uptrace_redis_password

# Seed account. Seed is opt-in (`make seed`) and refuses production mode.
SEED_USER_EMAIL=demo@bookflow.local
SEED_USER_PASSWORD=BookFlow-demo-only-2026!
SEED_USER_NAME=Demo Reader
