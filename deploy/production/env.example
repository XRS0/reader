# Reference only. Values beginning __INJECT are secret-manager placeholders.
APP_ENV=production
BOOKFLOW_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json
HTTP_ADDR=:8080
HTTP_TRUSTED_PROXIES=10.0.0.0/8

DATABASE_URL=__INJECT_POSTGRES_TLS_URL__
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=20
DATABASE_CONN_MAX_LIFETIME=30m

JWT_SIGNING_KEY=__INJECT_JWT_SIGNING_KEY__
JWT_ISSUER=bookflow
JWT_AUDIENCE=bookflow-web
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
CSRF_SECRET=__INJECT_DISTINCT_CSRF_SECRET__
COOKIE_NAME=bookflow_session
COOKIE_DOMAIN=reader.example.org
COOKIE_PATH=/
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

RUSTFS_ENDPOINT=https://rustfs.internal.example.org
RUSTFS_PUBLIC_ENDPOINT=https://books.example.org
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY=__INJECT_LEAST_PRIVILEGE_S3_ACCESS_KEY__
RUSTFS_SECRET_KEY=__INJECT_LEAST_PRIVILEGE_S3_SECRET_KEY__
RUSTFS_USE_PATH_STYLE=true
RUSTFS_PRESIGN_TTL=5m
RUSTFS_OPERATION_TIMEOUT=30s

CORS_ALLOWED_ORIGINS=https://reader.example.org
CORS_ALLOW_CREDENTIALS=true
UPLOAD_MAX_BYTES=104857600
EPUB_MAX_FILES=10000
EPUB_MAX_UNCOMPRESSED_BYTES=524288000
EPUB_MAX_COMPRESSION_RATIO=100

READING_HEARTBEAT_INTERVAL=15s
READING_MAX_CREDIT_INTERVAL=30s
READING_IDLE_THRESHOLD=60s
READING_STALE_AFTER=2m
WORKER_CONCURRENCY=8
WORKER_POLL_INTERVAL=1s
WORKER_JOB_TIMEOUT=5m
WORKER_MAX_ATTEMPTS=5

TRANSLATION_PROVIDER=mock
TRANSLATION_API_KEY=__INJECT_ONLY_IF_EXTERNAL_PROVIDER__
TRANSLATION_MODEL=__REVIEW_PROVIDER_MODEL__
TRANSLATION_PROMPT_VERSION=v1
TRANSLATION_TIMEOUT=10s
TRANSLATION_MAX_TEXT_RUNES=2000

OTEL_ENABLED=true
OTEL_SERVICE_NAME=bookflow
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.internal.example.org:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_INSECURE=false
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.namespace=bookflow

VITE_API_BASE_URL=/api/v1
